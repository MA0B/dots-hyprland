default partial alphanumeric_keys
xkb_symbols "basic" {
    include "us(intl)"
    name[Group1]= "English (US, intl., with dead keys)";

    // katakana/hiragana nao existem fisicamente neste teclado e nao sao
    // tocadas por nenhum outro componente do XKB (ao contrario de F13-F24,
    // que sao redefinidas depois por inet(evdev) e ignoram overrides aqui).
    // O keyd usa esse canal para emitir cedilha direto, sem depender de
    // composicao feita pelo app (Chromium/Electron ignora Compose custom).
    override key <KATA> { [ ccedilla, ccedilla ] };
    override key <HIRA> { [ Ccedilla, Ccedilla ] };
};
